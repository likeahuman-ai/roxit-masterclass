{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Workshop default = open. Visma IT can layer /etc/claude-code/managed-settings.json on top to restrict (managed settings always win over project + user settings).",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "ask": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)"
    ],
    "deny": [
      "Read(/home/dev/.ssh/**)",
      "Read(/home/dev/.aws/**)",
      "Read(/home/dev/.gnupg/**)",
      "Read(/etc/shadow)",
      "Bash(:(){ :|:& };:)"
    ]
  },
  "plugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "gsap-skills@gsap-skills": true,
    "branding-pitch@likeahuman-plugins": true,
    "font-hunt@likeahuman-plugins": true
  },
  "extraKnownMarketplaces": {
    "gsap-skills": {
      "source": {
        "source": "github",
        "repo": "greensock/gsap-skills"
      }
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "likeahuman-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/likeahuman-ai/claude-plugins.git"
      }
    }
  }
}
