{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "Roxit Masterclass",
  "image": "ghcr.io/likeahuman-ai/roxit-masterclass:latest",

  "remoteUser": "dev",
  "workspaceFolder": "/workspace",

  "mounts": [
    "source=roxit-claude-data,target=/home/dev/.claude,type=volume"
  ],

  "forwardPorts": [3000, 3001, 8080],
  "portsAttributes": {
    "3000": { "label": "Dev server", "onAutoForward": "notify" },
    "3001": { "label": "Secondary", "onAutoForward": "silent" },
    "8080": { "label": "Preview", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "telemetry.telemetryLevel": "off"
      }
    }
  },

  "shutdownAction": "stopContainer"
}
